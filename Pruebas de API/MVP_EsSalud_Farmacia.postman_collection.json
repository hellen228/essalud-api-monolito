  "item": [
    {
      "name": "Consultar Stock Kardex",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El código de estado HTTP debe ser 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"La respuesta debe contener los datos exactos del medicamento\", function () {",
              "    var jsonData = pm.response.json();",
              "    ",
              "    pm.expect(jsonData).to.have.property('idMedicamento');",
              "    pm.expect(jsonData).to.have.property('nombreFarmaco');",
              "    pm.expect(jsonData).to.have.property('stockActual');",
              "    pm.expect(jsonData).to.have.property('esControlado');",
              "    ",
              "    pm.expect(jsonData.stockActual).to.be.a('number');",
              "    pm.expect(jsonData.stockActual).to.equal(500); ",
              "    pm.expect(jsonData.esControlado).to.be.false; ",
              "    pm.expect(jsonData.mensaje).to.equal(\"Stock consultado con éxito\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/farmacia/stock/1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "farmacia",
            "stock",
            "1"
          ]
        }
      },
      "response": []
    }
  ]
