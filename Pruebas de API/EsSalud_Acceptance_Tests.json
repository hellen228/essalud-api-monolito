  "item": [
    {
      "name": "Acreditación",
      "item": [
        {
          "name": "Validar Cobertura por DNI",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// GIVEN: DNI con aportes al día (72266171)",
                  "// WHEN: GET a /api/acreditacion/{dni}",
                  "// THEN: Retorna 200 OK y seguro_activo: true",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Cobertura activa\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.seguroActivo).to.eql(true);",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 5s\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "GET {{project_host}}/api/acreditacion/{{dni}}",
              "host": [
                "GET {{project_host}}"
              ],
              "path": [
                "api",
                "acreditacion",
                "{{dni}}"
              ]
            },
            "description": "Valida la cobertura médica de un asegurado en EsSalud mediante su DNI."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}